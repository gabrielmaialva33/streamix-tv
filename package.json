{
  "name": "streamix-tv",
  "version": "1.0.0",
  "description": "Streamix IPTV App for Samsung Smart TV - LightningJS + SolidJS",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "vite --open --host --force",
    "start:prod": "vite --open --host --force --mode production",
    "start:tizen": "TARGET_DEVICE=tizen vite --open --host --force",
    "build": "vite build --sourcemap=true",
    "build:tizen": "TARGET_DEVICE=tizen vite build --mode production",
    "tizen:package": "cd dist/tizen && tizen package -t wgt -s StreamixTV -- .",
    "tizen:install": "cd dist/tizen && tizen install -n Streamix.wgt -s 192.168.1.6:26101",
    "tizen:run": "tizen run -p EI8qhrd7xh.streamix -s 192.168.1.6:26101",
    "tizen:kill": "tizen kill -p EI8qhrd7xh.streamix -s 192.168.1.6:26101",
    "tizen:uninstall": "tizen uninstall -p EI8qhrd7xh.streamix -s 192.168.1.6:26101",
    "tizen:install:emu": "cd dist/tizen && tizen install -n Streamix.wgt -t T-samsung-10.0-x86_64",
    "tizen:run:emu": "tizen run -p EI8qhrd7xh.streamix -t T-samsung-10.0-x86_64",
    "tizen:deploy": "pnpm build:tizen && pnpm tizen:package && pnpm tizen:install && pnpm tizen:run",
    "tizen:deploy:emu": "pnpm build:tizen && pnpm tizen:package && pnpm tizen:install:emu && pnpm tizen:run:emu",
    "tizen:logs": "sdb -s 192.168.1.6:26101 dlog -c WebCore:* ConsoleMessage:* *:E",
    "logs": "node scripts/log-server.js",
    "build:analyze": "vite-bundle-visualizer",
    "preview": "vite preview --open --port 8080",
    "test": "vitest",
    "tsc": "tsc",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "lint": "eslint '**/*.{js,ts,jsx,tsx}' --format stylish --ignore-pattern 'dist/*' --ignore-pattern 'node_modules'",
    "lint-fix": "eslint '**/*.{js,ts,jsx,tsx}' --fix  --ignore-pattern 'dist/*' --ignore-pattern 'node_modules'",
    "format": "prettier --write '**/*.{js,ts,jsx,tsx,json,md,css,html}' --ignore-path .prettierignore",
    "format:check": "prettier --check '**/*.{js,ts,jsx,tsx,json,md,css,html}' --ignore-path .prettierignore"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@lightningjs/renderer": "^3.0.1",
    "@lightningtv/solid": "^3.1.18",
    "@solid-primitives/i18n": "^2.2.1",
    "@solidjs/router": "^0.16.1",
    "hls.js": "^1.6.16",
    "lodash-es": "^4.18.1",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/js": "^10.0.1",
    "@lightningtv/vite-hex-transform": "^1.1.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-links": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitest/browser": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "^10.3.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.2",
    "storybook": "^10.3.5",
    "storybook-solidjs-vite": "^10.0.12",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-cross-origin-isolation": "^0.1.6",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.4",
    "ws": "^8.20.0"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "packageManager": "pnpm@9.4.0+sha512.f549b8a52c9d2b8536762f99c0722205efc5af913e77835dbccc3b0b0b2ca9e7dc8022b78062c17291c48e88749c70ce88eb5a74f1fa8c4bf5e18bb46c8bd83a"
}
